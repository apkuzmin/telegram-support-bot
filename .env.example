BOT_TOKEN=123456:ABCDEF_your_token_here
# Supergroup chat id (usually starts with -100...)
OPERATOR_GROUP_ID=-1001234567890
# Path to SQLite DB file
DB_PATH=./support_bot.sqlite3
LOG_LEVEL=INFO
# Store messages history in SQLite (set to 0 to disable)
LOG_MESSAGES=1
# Greeting sent in response to /start
START_MESSAGE=Hello! How can I help you?

# Headless omnichannel module
SUPPORT_ENV=development
# Production example:
# SUPPORT_DATABASE_URL=postgresql+asyncpg://support:password@localhost:5432/support
SUPPORT_DATABASE_URL=sqlite+aiosqlite:///./support_omnichannel.sqlite3
# Generate at least 32 random bytes, for example: openssl rand -hex 32
# Required when SUPPORT_ENV is not development. Never expose it to browsers.
SUPPORT_AUTH_SECRET=
# Exact comma-separated website origins allowed to call the API.
SUPPORT_ALLOWED_ORIGINS=http://localhost:3000
# Required outside development. Comma-separated HTTP Host allowlist.
SUPPORT_TRUSTED_HOSTS=localhost,127.0.0.1
# Keep disabled on a public production host unless docs are protected.
SUPPORT_EXPOSE_DOCS=1
SUPPORT_UPLOAD_DIR=./support_uploads
SUPPORT_MAX_UPLOAD_BYTES=10485760
SUPPORT_TOKEN_TTL_SECONDS=86400
SUPPORT_WEBSOCKET_IDLE_SECONDS=300
SUPPORT_REALTIME_RETENTION_SECONDS=604800
SUPPORT_OUTBOX_RETENTION_SECONDS=2592000
SUPPORT_UNUSED_FILE_RETENTION_SECONDS=86400
SUPPORT_MAINTENANCE_INTERVAL_SECONDS=3600
